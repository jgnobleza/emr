# Template for Render's Environment page or for a local shell export.
# Use Render's External Database URL locally.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Alternative ASP.NET Core style, also supported by this app:
# ConnectionStrings__DefaultConnection=Host=HOST;Port=5432;Database=DATABASE;Username=USER;Password=PASSWORD;SSL Mode=Require;
