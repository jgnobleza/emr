@model medrec.ViewModels.AdminPageViewModel

@{
    ViewData["Title"] = "Administration";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">Administrator only</p>
        <h1>Administration</h1>
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.DataNotice))
{
    <div class="system-alert">@Model.DataNotice</div>
}

<section class="admin-grid">
    <article class="panel">
        <div class="panel-header">
            <div>
                <h2>Doctor accounts</h2>
                <p class="text-muted mb-0">Create credentials for doctors who use MedRec.</p>
            </div>
        </div>

        <form asp-action="CreateDoctor" method="post" class="account-form">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div>
                <label asp-for="NewDoctor.FullName" class="form-label"></label>
                <input asp-for="NewDoctor.FullName" class="form-control" autocomplete="name">
                <span asp-validation-for="NewDoctor.FullName" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="NewDoctor.Email" class="form-label"></label>
                <input asp-for="NewDoctor.Email" class="form-control" autocomplete="username">
                <span asp-validation-for="NewDoctor.Email" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="NewDoctor.Password" class="form-label"></label>
                <input asp-for="NewDoctor.Password" class="form-control" autocomplete="new-password">
                <span asp-validation-for="NewDoctor.Password" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="NewDoctor.ConfirmPassword" class="form-label"></label>
                <input asp-for="NewDoctor.ConfirmPassword" class="form-control" autocomplete="new-password">
                <span asp-validation-for="NewDoctor.ConfirmPassword" class="text-danger"></span>
            </div>
            <button class="btn btn-primary" type="submit">Create doctor account</button>
        </form>

        <div class="table-responsive account-table">
            <table class="table app-table">
                <thead><tr><th>Name</th><th>Username / email</th><th>Role</th><th>Status</th></tr></thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.FullName</td>
                        <td>@user.Email</td>
                        <td><span class="role-badge">@user.Role</span></td>
                        <td>@(user.IsActive ? "Active" : "Inactive")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </article>

    <article class="panel">
        <div class="panel-header">
            <div>
                <h2>Archived patients</h2>
                <p class="text-muted mb-0">Restore patients that were removed from the active patient list.</p>
            </div>
        </div>

        @if (Model.ArchivedPatients.Count == 0)
        {
            <p class="empty-state">There are no archived patients.</p>
        }
        else
        {
            <div class="table-responsive account-table">
                <table class="table app-table">
                    <thead>
                    <tr><th>Patient no.</th><th>Name</th><th>Age</th><th>Sex</th><th>Archived</th><th></th></tr>
                    </thead>
                    <tbody>
                    @foreach (var patient in Model.ArchivedPatients)
                    {
                        <tr>
                            <td>@patient.PatientNumber</td>
                            <td>@patient.FullName</td>
                            <td>@patient.Age</td>
                            <td>@patient.Sex</td>
                            <td>@patient.ArchivedAt?.ToString("MMM d, yyyy h:mm tt")</td>
                            <td>
                                <form asp-action="UnarchivePatient" method="post" data-confirm="Restore this patient to the active list?">
                                    <input type="hidden" name="id" value="@patient.Id">
                                    <button class="btn btn-outline-primary" type="submit">Restore</button>
                                </form>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </article>

    <article class="panel">
        <div class="panel-header">
            <div>
                <h2>Document layouts</h2>
                <p class="text-muted mb-0">Manage the templates doctors use when printing.</p>
            </div>
        </div>
        <div class="layout-admin-actions">
            <button class="btn btn-primary" type="button" data-bs-toggle="modal" data-bs-target="#prescriptionLayoutModal">Edit prescription layout</button>
            <button class="btn btn-outline-primary" type="button" data-bs-toggle="modal" data-bs-target="#diagnosisLayoutModal">Edit diagnosis layout</button>
        </div>
    </article>

    <article class="panel">
        <h2>System settings</h2>
        <dl class="settings-list">
            <div><dt>Patient images</dt><dd><code>wwwroot/uploads/patients</code></dd></div>
            <div><dt>Automatic sync</dt><dd>Daily at 6:00 PM</dd></div>
            <div><dt>Database</dt><dd>Render PostgreSQL connection can be edited below.</dd></div>
        </dl>

        <form asp-action="TestPostgresConnection" method="post" class="account-form mt-3">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div>
                <label asp-for="PostgresSettings.ConnectionString" class="form-label"></label>
                <textarea asp-for="PostgresSettings.ConnectionString" class="form-control" rows="4" spellcheck="false" autocomplete="off" placeholder="postgresql://user:password@host/database"></textarea>
                <span asp-validation-for="PostgresSettings.ConnectionString" class="text-danger"></span>
                <p class="text-muted mt-2 mb-0">Paste Render's External Database URL for desktop/local use, or Internal Database URL when this app is running on Render beside the database.</p>
            </div>
            <div class="layout-admin-actions">
                <button class="btn btn-outline-primary" type="submit">Test connection</button>
                <button class="btn btn-primary" type="submit" formaction="@Url.Action("SavePostgresSettings", "Admin")">Save connection</button>
                <button class="btn btn-outline-secondary" type="submit" formaction="@Url.Action("InitializePostgresDatabase", "Admin")" data-confirm="Initialize MedRec tables on this PostgreSQL database?">Initialize database tables</button>
            </div>
        </form>

        <hr>

        <form asp-action="TestGoogleDriveSettings" method="post" class="account-form mt-3">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div>
                <label asp-for="GoogleDriveSettings.ApplicationName" class="form-label"></label>
                <input asp-for="GoogleDriveSettings.ApplicationName" class="form-control" autocomplete="off">
                <span asp-validation-for="GoogleDriveSettings.ApplicationName" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="GoogleDriveSettings.FolderId" class="form-label"></label>
                <input asp-for="GoogleDriveSettings.FolderId" class="form-control" autocomplete="off" placeholder="Google Drive folder ID">
                <span asp-validation-for="GoogleDriveSettings.FolderId" class="text-danger"></span>
                <p class="text-muted mt-2 mb-0">Share this folder with the service account email from your JSON credentials.</p>
            </div>
            <div>
                <label asp-for="GoogleDriveSettings.ServiceAccountJson" class="form-label"></label>
                <textarea asp-for="GoogleDriveSettings.ServiceAccountJson" class="form-control" rows="5" spellcheck="false" autocomplete="off" placeholder="{ &quot;type&quot;: &quot;service_account&quot;, ... }"></textarea>
                <span asp-validation-for="GoogleDriveSettings.ServiceAccountJson" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="GoogleDriveSettings.ServiceAccountJsonBase64" class="form-label"></label>
                <textarea asp-for="GoogleDriveSettings.ServiceAccountJsonBase64" class="form-control" rows="3" spellcheck="false" autocomplete="off"></textarea>
                <span asp-validation-for="GoogleDriveSettings.ServiceAccountJsonBase64" class="text-danger"></span>
            </div>
            <div>
                <label asp-for="GoogleDriveSettings.ServiceAccountJsonPath" class="form-label"></label>
                <input asp-for="GoogleDriveSettings.ServiceAccountJsonPath" class="form-control" autocomplete="off" placeholder="C:\path\service-account.json">
                <span asp-validation-for="GoogleDriveSettings.ServiceAccountJsonPath" class="text-danger"></span>
            </div>
            <div class="layout-admin-actions">
                <button class="btn btn-outline-primary" type="submit">Test Google Drive</button>
                <button class="btn btn-primary" type="submit" formaction="@Url.Action("SaveGoogleDriveSettings", "Admin")">Save Google Drive</button>
            </div>
        </form>
    </article>
</section>

<partial name="~/Views/Reports/_PrintLayoutModal.cshtml" model="@(new medrec.ViewModels.PrintLayoutEditorViewModel
{
    ModalId = "prescriptionLayoutModal", Action = "UpdatePrescriptionLayout", Controller = "Admin",
    Prefix = "PrescriptionLayoutForm", Title = "Prescription Layout",
    Layout = Model.PrescriptionLayout, Form = Model.PrescriptionLayoutForm
})" />

<partial name="~/Views/Reports/_PrintLayoutModal.cshtml" model="@(new medrec.ViewModels.PrintLayoutEditorViewModel
{
    ModalId = "diagnosisLayoutModal", Action = "UpdateDiagnosisLayout", Controller = "Admin",
    Prefix = "DiagnosisLayoutForm", Title = "Diagnosis Layout",
    Layout = Model.DiagnosisLayout, Form = Model.DiagnosisLayoutForm
})" />

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

