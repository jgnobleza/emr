@model medrec.ViewModels.DoctorProfileViewModel

@{
    ViewData["Title"] = "Professional Settings";
}

<section class="page-heading">
    <div>
        <p class="eyebrow">My profile</p>
        <h1>Professional Settings</h1>
    </div>
</section>

<section class="panel profile-settings-panel">
    <form asp-action="Index" method="post" enctype="multipart/form-data" class="profile-settings-form">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div>
            <label asp-for="FullName" class="form-label"></label>
            <input asp-for="FullName" class="form-control" autocomplete="name">
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="Specialty" class="form-label"></label>
            <input asp-for="Specialty" class="form-control" placeholder="e.g. OB-Gyne Ultrasound Subspecialist">
            <span asp-validation-for="Specialty" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="LicenseNumber" class="form-label"></label>
            <input asp-for="LicenseNumber" class="form-control">
            <span asp-validation-for="LicenseNumber" class="text-danger"></span>
        </div>
        <div>
            <label asp-for="ContactNumber" class="form-label"></label>
            <input asp-for="ContactNumber" class="form-control" autocomplete="tel">
            <span asp-validation-for="ContactNumber" class="text-danger"></span>
        </div>
        <div>
            <label class="form-label">Login username / email</label>
            <input value="@Model.Email" class="form-control" disabled>
        </div>
        <div>
            <label asp-for="Signature" class="form-label"></label>
            <input asp-for="Signature" class="form-control" accept="image/png,image/jpeg,image/gif,image/webp">
            <span asp-validation-for="Signature" class="text-danger"></span>
            <small class="form-text text-muted">Use a cropped signature on a transparent or white background.</small>
        </div>

        <div class="signature-settings-preview">
            <span>Current signature</span>
            @if (!string.IsNullOrWhiteSpace(Model.SignatureUrl))
            {
                <img src="@Model.SignatureUrl" alt="Current signature">
            }
            else
            {
                <strong>No signature uploaded</strong>
            }
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" type="submit">Save professional profile</button>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
