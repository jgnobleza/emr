                        </div>
                        <div>
                            <label asp-for="EditPatient.WeightKg" class="form-label">Weight (kg)</label>
                            <input asp-for="EditPatient.WeightKg" type="number" step="0.01" min="0" class="form-control" data-weight-input>
                        </div>
                        <div>
                            <label asp-for="EditPatient.BloodPressure" class="form-label"></label>
                            <input asp-for="EditPatient.BloodPressure" class="form-control">
                        </div>
                        <div>
                            <label asp-for="EditPatient.FetalHeartTone" class="form-label"></label>
                            <input asp-for="EditPatient.FetalHeartTone" class="form-control">
                        </div>
                        <div>
                            <label class="form-label">BMI</label>
                            <input class="form-control" readonly data-bmi-output>
                        </div>
                        <div>
                            <label asp-for="EditPatient.LastMenstrualPeriod" class="form-label"></label>
                            <input asp-for="EditPatient.LastMenstrualPeriod" type="date" class="form-control" data-lmp-input>
                        </div>
                        <div>
                            <label class="form-label">Age of Gestation</label>
                            <input class="form-control" readonly data-aog-output>
                        </div>
                        <div>
                            <label class="form-label">EDD</label>
                            <input class="form-control" readonly data-edd-output>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">Cancel</button>
                    <button class="btn btn-primary" type="submit">Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
